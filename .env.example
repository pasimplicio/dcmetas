# ===== Servidor =====
PORT=3001

# ===== Banco de Dados SQLite =====
# Local: database.sqlite
# Docker: /app/data/database.sqlite
SQLITE_PATH=database.sqlite

# ===== Frontend (CORS) =====
FRONTEND_URL=http://localhost:5173

# ===== Proteção de Rotas Administrativas =====
# Deixe vazio para desabilitar proteção (ambiente de desenvolvimento)
API_ADMIN_TOKEN=

# ===== Datasource Ativo =====
# Valores: sqlite | postgres
DATA_SOURCE=sqlite

# ===== PostgreSQL (somente leitura) =====
PG_HOST=
PG_PORT=5432
PG_DATABASE=
PG_USER=
PG_PASSWORD=
